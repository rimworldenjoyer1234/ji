{
  "schema_version": 2,
  "id": "linux-aarch64-generic-arm-v1",
  "os": "linux",
  "arch": "aarch64",
  "cpu_vendor": "generic-arm",
  "match": {
    "virtualization": "baremetal",
    "cpu_model_family": "arm-*",
    "logical_cpu_min": 1,
    "logical_cpu_max": 256
  },
  "runtime": {
    "disable_memory_access": false,
    "force_internal_timer": false,
    "disable_internal_timer": false,
    "force_fips": false,
    "ntg1": false,
    "cache_all": false,
    "max_memsize": 256,
    "hashloop": 1
  },
  "osr": 4,
  "smoke_bytes": 64
}
